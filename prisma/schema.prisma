generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductType {
  REBAR
  PROFILE
}

enum OrderStatus {
  NEW
  PROCESSING
  CONFIRMED
  PICKING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  NEW_ORDER
  ORDER_STATUS
  STOCK_ALERT
  SYSTEM
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id            String             @id @default(cuid())
  slug          String             @unique
  companyName   String
  productType   ProductType
  title         String
  description   String             @db.Text
  phone         String
  telegram      String?
  photos        String[]
  isActive      Boolean            @default(true)
  size          String?
  length        String?
  meterPerTon   Decimal?           @db.Decimal(10, 2)
  piecesPerTon  Decimal?           @db.Decimal(10, 2)
  pricePerTon   Decimal?           @db.Decimal(12, 2)
  pricePerPiece Decimal?           @db.Decimal(12, 2)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  attributes    ProductAttribute[]
  inventory     Inventory?
  orderItems    OrderItem[]
}

model ProductAttribute {
  id        String   @id @default(cuid())
  productId String
  key       String
  value     String
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Inventory {
  id        String   @id @default(cuid())
  productId String   @unique
  inStock   Int      @default(0)
  reserved  Int      @default(0)
  available Int      @default(0)
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id                String        @id @default(cuid())
  customerName      String
  phone             String
  telegram          String?
  comment           String?       @db.Text
  status            OrderStatus   @default(NEW)
  internalNotes     String?       @db.Text
  inventoryAdjusted Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  items             OrderItem[]
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String
  productId        String
  quantity         Int
  productTitle     String
  productSlug      String
  productTypeLabel String
  unitPrice        Decimal? @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String           @db.Text
  isRead      Boolean          @default(false)
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model StoreSetting {
  id            Int      @id
  companyName   String
  phone         String
  telegram      String?
  address       String?
  heroTitle     String
  heroSubtitle  String   @db.Text
  aboutText     String   @db.Text
  updatedAt     DateTime @updatedAt
}
